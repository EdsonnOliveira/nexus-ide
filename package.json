{
  "name": "nexus-ide",
  "version": "1.0.20",
  "private": true,
  "description": "Nexus IDE — AI-powered desktop IDE",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "node scripts/patch-electron-branding.mjs && env -u NODE_OPTIONS vite",
    "build": "tsc --noEmit && vite build && electron-builder",
    "build:local": "node scripts/build-shell-helpers.mjs && tsc --noEmit && vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder && node scripts/finish-mac-local-build.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/setup-native.mjs",
    "rebuild:native": "node scripts/setup-native.mjs"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@uiw/codemirror-theme-monokai": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-store": "^10.0.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.460.0",
    "macos-calendar": "file:native/macos-calendar",
    "material-icon-theme": "^5.35.0",
    "node-pty": "^1.0.0",
    "vis-data": "^8.0.4",
    "vis-network": "^10.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/vis": "^4.21.27",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.1",
    "node-addon-api": "^8.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.1",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "build": {
    "appId": "com.nexus.ide",
    "productName": "Nexus IDE",
    "icon": "build/icon.png",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron",
      "dist",
      "resources/shell",
      "resources/simulator-server",
      "build/icon.icns",
      "build/icon.ico",
      "build/icon.png"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**/*",
      "**/node_modules/macos-calendar/**/*",
      "**/node_modules/@vscode/ripgrep/**/*",
      "**/node_modules/@vscode/ripgrep-*/**/*",
      "resources/shell/**/*",
      "resources/simulator-server/**/*"
    ],
    "extraFiles": [
      {
        "from": "resources/shell/CalendarHelper-Info.plist",
        "to": "Helpers/CalendarHelper.app/Contents/Info.plist"
      },
      {
        "from": "resources/shell/macosCalendarHelper",
        "to": "Helpers/CalendarHelper.app/Contents/MacOS/CalendarHelper"
      },
      {
        "from": "resources/shell/NotificationHelper.app",
        "to": "Helpers/NotificationHelper.app"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "extraResources": [
        "build/Assets.car"
      ],
      "extendInfo": {
        "CFBundleDisplayName": "Nexus",
        "CFBundleName": "Nexus IDE",
        "CFBundleIconName": "Nexus",
        "NSCalendarsUsageDescription": "O Nexus IDE exibe seus eventos do Calendário na barra lateral.",
        "NSCalendarsFullAccessUsageDescription": "O Nexus IDE precisa ler seus eventos do Calendário para exibi-los na barra lateral."
      },
      "x64ArchFiles": "{**/node-pty/**,**/Contents/Helpers/**,**/macos-calendar/**,**/resources/shell/**,**/@vscode/ripgrep*/**}",
      "identity": "-",
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "packageManager": "yarn@1.22.19+sha512.ff4579ab459bb25aa7c0ff75b62acebe576f6084b36aa842971cf250a5d8c6cd3bc9420b22ce63c7f93a0857bc6ef29291db39c3e7a23aab5adfd5a4dd6c5d71"
}
