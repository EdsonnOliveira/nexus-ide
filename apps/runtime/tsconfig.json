{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@nexus/protocol": ["../../packages/protocol/src/index.ts"],
      "@nexus/supabase": ["../../packages/supabase/src/index.ts"]
    }
  },
  "include": ["src"]
}
