<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.nexus.runtime</string>
    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd "$HOME/DEV/DESKTOP/nexus-ide" &amp;&amp; source ~/.nvm/nvm.sh &amp;&amp; nvm use &amp;&amp; npm run runtime</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/nexus-runtime.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/nexus-runtime.err</string>
  </dict>
</plist>
